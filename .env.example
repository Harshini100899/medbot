# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="P4H MedBot - Oberhausen"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000


# ─── LLM Provider: "ollama" | "openai" | "anthropic" | "groq" ──────────────────
LLM_PROVIDER=ollama

# Groq (optional)
#GROQ_API_KEY=gsk_...
#GROQ_MODEL=openai/gpt-oss-120b

# Ollama (local — install from https://ollama.ai then: ollama pull llama3.2:3b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# OpenAI (optional — comment out if using Ollama)
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional — comment out if using Ollama)
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-3-haiku-20240307


# ─── Memory / Databases ───────────────────────────────────────────────────────
# Short-term memory — open-source Redis (Docker: docker compose up -d redis)
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# Long-term persistence — MongoDB (Docker: docker compose up -d mongodb)
MONGO_ENABLED=true
MONGODB_URL=mongodb://admin:password@localhost:27017
MONGODB_DB=medbot
MONGODB_AUTH_SOURCE=admin

# ChromaDB (local persistent — no Docker needed)
CHROMA_PERSIST_DIR=./data/chroma_db

# ─── Observability (Langfuse) — optional; leave blank to disable ──────────────
# Get keys from https://cloud.langfuse.com or a self-hosted instance.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Embedding Model ──────────────────────────────────────────────────────────
# Auto-downloaded from HuggingFace on first run (~120MB)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu

# ─── External APIs ────────────────────────────────────────────────────────────
# Tavily web search (free tier: https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# Google Maps API (optional — for real maps/directions)
#GOOGLE_MAPS_API_KEY=AIza...

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500","http://localhost:3000","http://localhost:8080"]

# ─── Supported Languages ──────────────────────────────────────────────────────
# DE=German, EN=English, TR=Turkish, UK=Ukrainian
DEFAULT_LANGUAGE=en
