# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="P4H MedBot - Oberhausen"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ─── LLM Provider: "ollama" | "openai" | "anthropic" ─────────────────────────
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=medgemma

# ─── Memory / Databases ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

MONGODB_URL=mongodb://admin:password@localhost:27017
MONGODB_DB=medbot

CHROMA_PERSIST_DIR=./data/chroma_db

# ─── Embedding Model ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu

# ─── External APIs ────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-placeholder

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500","http://localhost:3000","http://localhost:8080"]

# ─── Supported Languages ──────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
